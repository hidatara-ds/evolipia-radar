{
  "version": 2,
  "builds": [
    {
      "src": "api/*.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/news",
      "dest": "/api/news.go",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/trending",
      "dest": "/api/trending.go",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/search",
      "dest": "/api/search.go",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/healthz",
      "dest": "/api/health.go",
      "methods": ["GET"]
    },
    {
      "src": "/metrics",
      "dest": "/api/metrics.go",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/v2/crawl/trigger",
      "dest": "/api/trigger.go",
      "methods": ["POST", "OPTIONS"]
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
