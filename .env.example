# Database Configuration
DATABASE_URL=postgresql://evolipia-radar_owner:yourpswrd@ep-quiet-butterfly-a1qlqxqy.ap-southeast-1.aws.neon.tech/evolipia-radar?sslmode=require

# API Server Configuration
PORT=8080
CACHE_TTL_SECONDS=60

# Worker Configuration
WORKER_CRON=*/10 * * * *  # Every 10 minutes

# Fetcher Configuration
MAX_FETCH_BYTES=2000000  # 2MB
FETCH_TIMEOUT_SECONDS=8

# LLM Configuration (OpenRouter)
LLM_PROVIDER=openrouter
LLM_MODEL=google/gemini-flash-1.5
LLM_FALLBACK_MODELS=anthropic/claude-3.5-sonnet,meta-llama/llama-3.1-70b-instruct
LLM_API_KEY=your_openrouter_api_key_here
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
LLM_ENABLED=true
